{
  "manifest_version": 3,
  "name": "Rubrical",
  "description": "Check your assignment against the rubric before you submit.",
  "version": "0.1.0",
  "key": "",
  "permissions": ["activeTab", "storage"],
  "host_permissions": [
    "https://*.instructure.com/*",
    "http://localhost:8787/*",
    "http://127.0.0.1:8787/*",
    "https://rubrical.spencerls.dev/*"
  ],
  "background": {
    "service_worker": "dist/background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*.instructure.com/*"],
      "js": ["dist/content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Rubrical",
    "default_popup": "popup.html"
  }
}
