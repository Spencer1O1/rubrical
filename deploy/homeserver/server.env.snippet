# Append to /etc/homeserver/server.env (loaded by Caddy and rubrical.service).
# Shared infra host/ports live here — not in apps/rubrical.env.
# See HOMESERVER.md §8 for Postgres + MinIO conventions.

POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

MINIO_HOST=127.0.0.1
MINIO_PORT=9100

RUBRICAL_HOST=127.0.0.1
RUBRICAL_PORT=8787

RUBRICAL_HOOK_HOST=127.0.0.1
RUBRICAL_HOOK_PORT=9011
