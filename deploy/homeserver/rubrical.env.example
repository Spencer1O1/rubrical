# Copy to /etc/homeserver/apps/rubrical.env (not loaded from the git checkout).
# Ownership: root:<deploy-user> mode 640 — deploy.sh sources this; systemd uses EnvironmentFile=.
#
# Listen host/port live ONLY in /etc/homeserver/server.env (RUBRICAL_* + POSTGRES_HOST/PORT).
# See docs/configuration.md for the full variable list.

RUBRICAL_PUBLIC_URL=https://rubrical.spencerls.dev

# DB role/password/name only — host/port from server.env (POSTGRES_HOST / POSTGRES_PORT).
POSTGRES_USER=rubrical
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=rubrical
POSTGRES_SSLMODE=disable

RUBRICAL_DATA_DIR=/srv/repos/rubrical/data
RUBRICAL_SECRETS_ENCRYPTION_KEY=CHANGE_ME

# Stable ID from extension/manifest.json "key" (sideloaded zip from /install).
RUBRICAL_EXTENSION_ORIGINS=chrome-extension://mdjogmaimihfjhgobpajfpkbibgmecce

# Optional Google sign-in (Cloud Console OAuth client; see docs/deployment.md §9)
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=

# Password-reset email (pick one). Leave EMAIL_DEV_LOG unset in production.
# EMAIL_FROM="Rubrical <noreply@rubrical.spencerls.dev>"
# RESEND_API_KEY=
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
