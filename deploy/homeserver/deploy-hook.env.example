# Copy to /etc/homeserver/deploy-hooks/rubrical.env (mode 600).
#
# Host/port are NOT here — set RUBRICAL_HOOK_HOST / RUBRICAL_HOOK_PORT in
# /etc/homeserver/server.env. deploy-hook-rubrical.service maps them to
# DEPLOY_HOOK_* for the binary.
#
# Generate the secret (same value goes in GitHub → Webhooks → Secret):
#   openssl rand -hex 32

WEBHOOK_PATH=/_github/rubrical
GITHUB_WEBHOOK_SECRET=CHANGE_ME
DEPLOY_SCRIPT=/srv/deploy/rubrical/deploy.sh
DEPLOY_BRANCH=main
