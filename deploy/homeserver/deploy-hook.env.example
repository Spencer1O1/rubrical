# Copy to /etc/homeserver/deploy-hooks/rubrical.env (mode 600).
# Same shape as deploy-hooks/spencerls.env.
#
# Generate the secret (same value goes in GitHub → Webhooks → Secret):
#   openssl rand -hex 32
#
# DEPLOY_HOOK_PORT must match RUBRICAL_HOOK_PORT in /etc/homeserver/server.env
# (Caddy uses the latter; this binary uses the former).

WEBHOOK_PATH=/_github/rubrical
GITHUB_WEBHOOK_SECRET=CHANGE_ME
DEPLOY_SCRIPT=/srv/deploy/rubrical/deploy.sh
DEPLOY_HOOK_HOST=127.0.0.1
DEPLOY_HOOK_PORT=9011
DEPLOY_BRANCH=main
