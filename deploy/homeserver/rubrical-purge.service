[Unit]
Description=Rubrical draft-file purge
After=network-online.target postgresql.service
Requires=postgresql.service

[Service]
Type=oneshot
User=CHANGE_ME
WorkingDirectory=/srv/repos/rubrical
EnvironmentFile=/etc/homeserver/server.env
EnvironmentFile=/etc/homeserver/apps/rubrical.env
ExecStart=/srv/repos/rubrical/bin/rubrical-purge
