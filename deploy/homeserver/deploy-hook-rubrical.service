[Unit]
Description=GitHub deploy webhook for rubrical.spencerls.dev
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=CHANGE_ME
WorkingDirectory=/opt/deploy-hook
EnvironmentFile=/etc/homeserver/server.env
EnvironmentFile=/etc/homeserver/deploy-hooks/rubrical.env
Environment=PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
ExecStart=/opt/deploy-hook/bin/deploy-hook
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
