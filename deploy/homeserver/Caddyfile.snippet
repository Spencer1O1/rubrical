# Merge into /etc/caddy/Caddyfile.
# Host/port come only from /etc/homeserver/server.env (see server.env.snippet).

rubrical.spencerls.dev {
	@deployHook path /_github/rubrical /_github/rubrical/*
	handle @deployHook {
		reverse_proxy {$RUBRICAL_HOOK_HOST}:{$RUBRICAL_HOOK_PORT}
	}

	handle {
		reverse_proxy {$RUBRICAL_HOST}:{$RUBRICAL_PORT}
	}
}
