# Copy to .env.local and edit. Loaded automatically (.env.local overrides .env).
# See docs/development.md for details.

# Server
# RUBRICAL_ADDR=:8787
DATABASE_URL=postgres://rubrical:rubrical@localhost:5432/rubrical?sslmode=disable

# Draft file bytes on disk
RUBRICAL_DATA_DIR=./data

# Extension extraction: set 1 to disable Canvas fallbacks (dev/testing)
RUBRICAL_STRICT_EXTRACTION=0

# Purge uploaded draft files after retention (Go duration: 168h, 720h, 0 to disable a rule)
POST_DUE_DATE_RETENTION_TIME=168h
POST_UPLOAD_RETENTION_TIME=720h

# AI (Phase 7 — optional)
# AI_PROVIDER=openai
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
