# Copy to .env.local and edit. Loaded automatically (.env.local overrides .env).
# See docs/configuration.md — defaults live in internal/config/defaults.go; ENV only overrides operator tunables.

# --- Server ---
# RUBRICAL_ADDR=:8787
DATABASE_URL=postgres://rubrical:rubrical@localhost:5432/rubrical?sslmode=disable
RUBRICAL_DATA_DIR=./data

# --- Dev / ops ---
RUBRICAL_STRICT_EXTRACTION=0
# RUBRICAL_ALLOW_LOCAL_URL_FETCH=1
POST_DUE_DATE_RETENTION_TIME=168h
POST_UPLOAD_RETENTION_TIME=720h

# --- Draft uploads (storage; match Canvas-sized submissions, not analysis cost) ---
# DRAFT_MAX_UPLOAD_BYTES=524288000
# DRAFT_MAX_UPLOAD_SLOTS=20

# --- Analysis (what the model actually sees) ---
# ANALYSIS_MAX_SUBMISSION_TEXT_CHARS=120000
# ANALYSIS_MAX_TOTAL_BYTES=67108864

# --- Rate limits (off during BYOK beta) ---
# AI_ENFORCE_RATE_LIMITS=1
# AI_MAX_RUNS_PER_HOUR=10
# AI_MAX_RUNS_PER_DAY=50
# AI_MIN_SECONDS_BETWEEN_RUNS=30

# Per-user AI (provider, model, API keys) → Settings UI or extension popup, stored in DB.
# Not set in ENV.
