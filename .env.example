# Local development only — copy to .env.local (gitignored).
# Homeserver production: homeserver.yaml → /etc/homeserver/apps/rubrical.env
# (plus server.env listen/DB host, databases/rubrical.env for the DB role).

POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=rubrical
POSTGRES_PASSWORD=rubrical
POSTGRES_DB=rubrical
POSTGRES_SSLMODE=disable

# Listen (homeserver app key → RUBRICAL_* in server.env on the host)
RUBRICAL_HOST=
RUBRICAL_PORT=8787
PUBLIC_URL=http://localhost:8787
DATA_DIR=./data

# make setup / pnpm setup:secrets-key
SECRETS_ENCRYPTION_KEY=

# Auth / email (local: log mail to stdout)
EMAIL_DEV_LOG=1
EMAIL_FROM="Rubrical <rubrical@spencerls.dev>"
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
EXTENSION_ORIGINS=chrome-extension://mdjogmaimihfjhgobpajfpkbibgmecce
# SESSION_TTL=720h
# RESEND_API_KEY=
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=

# Dev / ops
STRICT_EXTRACTION=0
# ALLOW_LOCAL_URL_FETCH=1
POST_DUE_DATE_RETENTION_TIME=168h
POST_UPLOAD_RETENTION_TIME=720h

# Draft uploads (storage)
# DRAFT_MAX_UPLOAD_BYTES=524288000
# DRAFT_MAX_UPLOAD_SLOTS=20

# Analysis (what the model sees)
# ANALYSIS_MAX_SUBMISSION_TEXT_CHARS=120000
# ANALYSIS_MAX_TOTAL_BYTES=67108864

# Rate limits (off during BYOK beta)
# AI_ENFORCE_RATE_LIMITS=1
# AI_MAX_RUNS_PER_HOUR=10
# AI_MAX_RUNS_PER_DAY=50
# AI_MIN_SECONDS_BETWEEN_RUNS=30
