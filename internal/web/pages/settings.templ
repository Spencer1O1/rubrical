package pages

import (
	"fmt"

	"rubrical/internal/aisettings"
	"rubrical/internal/web/components"
)

var AIProviderOptions = []struct {
	ID    string
	Label string
}{
	{ID: "openai", Label: "OpenAI"},
	{ID: "anthropic", Label: "Anthropic"},
}

var OpenAIModelOptions = []struct {
	ID    string
	Label string
}{
	{ID: "gpt-4o-mini", Label: "GPT-4o mini (recommended)"},
	{ID: "gpt-4o", Label: "GPT-4o"},
	{ID: "gpt-4.1-mini", Label: "GPT-4.1 mini"},
	{ID: "gpt-4.1", Label: "GPT-4.1"},
}

var AnthropicModelOptions = []struct {
	ID    string
	Label string
}{
	{ID: "claude-sonnet-4-20250514", Label: "Claude Sonnet 4"},
	{ID: "claude-3-7-sonnet-20250219", Label: "Claude 3.7 Sonnet"},
	{ID: "claude-3-5-haiku-20241022", Label: "Claude 3.5 Haiku"},
}

templ SettingsPage(settings aisettings.Settings, user components.LayoutUser, errorMessage string, saved bool) {
	@components.Shell(components.ShellView{Kind: components.ShellApp, Title: "Settings", User: user}, settingsPageContent(settings, errorMessage, saved))
}

templ SettingsEmbed(settings aisettings.Settings, errorMessage string, assignmentBackURL string, assignmentID int64, saved bool) {
	@components.Shell(components.ShellView{Kind: components.ShellEmbed, Title: "AI settings"}, settingsEmbedContent(settings, errorMessage, assignmentBackURL, assignmentID, saved))
}

templ settingsEmbedContent(settings aisettings.Settings, errorMessage string, assignmentBackURL string, assignmentID int64, saved bool) {
	<section class="mx-auto max-w-xl space-y-4">
		<p class="text-sm">
			<a href={ assignmentBackURL } class="font-medium text-indigo-700 hover:text-indigo-900">← Back to draft</a>
		</p>
		if saved {
			<p class="rounded-lg border border-emerald-200 bg-emerald-50 px-3 py-2 text-sm text-emerald-800">Settings saved.</p>
		}
		<div>
			<h1 class="text-xl font-semibold tracking-tight">AI settings</h1>
			<p class="mt-2 text-sm text-stone-600">
				Provider, model, and API keys for analyze. Saved to your Rubrical account.
			</p>
		</div>
		@settingsEmbedForm(settings, errorMessage, assignmentID)
	</section>
}

templ settingsPageContent(settings aisettings.Settings, errorMessage string, saved bool) {
	<section class="mx-auto max-w-xl space-y-6">
		if saved {
			<p class="rounded-lg border border-emerald-200 bg-emerald-50 px-3 py-2 text-sm text-emerald-800">Settings saved.</p>
		}
		<div>
			<h1 class="text-2xl font-semibold tracking-tight">AI settings</h1>
			<p class="mt-2 text-sm text-stone-600">
				Your API keys are encrypted at rest on the Rubrical server and used only when you analyze a draft. During beta you bring your own keys; paid plans will use Rubrical-managed AI later.
			</p>
		</div>
		@settingsForm(settings, errorMessage, saved, false, 0)
	</section>
}

templ settingsEmbedForm(settings aisettings.Settings, errorMessage string, assignmentID int64) {
	@settingsForm(settings, errorMessage, false, true, assignmentID)
}

templ settingsForm(settings aisettings.Settings, errorMessage string, saved bool, embed bool, assignmentID int64) {
	<form
		method="post"
		action={ SettingsFormAction(embed, assignmentID) }
		class="space-y-4 rounded-xl border border-stone-200 bg-white p-5"
		if !embed {
			hx-post="/settings/ai"
			hx-target="#settings-status"
			hx-swap="innerHTML"
		}
	>
		if embed {
			<input type="hidden" name="embed" value="1"/>
			if assignmentID > 0 {
				<input type="hidden" name="assignment_id" value={ fmt.Sprintf("%d", assignmentID) }/>
			}
		}
		if errorMessage != "" {
			<p class="text-sm text-red-600">{ errorMessage }</p>
		}
		<label class="block space-y-1 text-sm font-medium text-stone-900">
			<span>Provider</span>
			<select name="provider" class="block w-full rounded-lg border border-stone-300 px-3 py-2">
				for _, option := range AIProviderOptions {
					<option
						value={ option.ID }
						data-model={ ProviderSavedModel(settings, option.ID) }
						selected?={ settings.Provider == option.ID }
					>{ option.Label }</option>
				}
			</select>
		</label>
		<label class="block space-y-1 text-sm font-medium text-stone-900">
			<span>Model</span>
			<select name="model" class="block w-full rounded-lg border border-stone-300 px-3 py-2">
				if settings.Provider == "anthropic" {
					for _, option := range AnthropicModelOptions {
						<option value={ option.ID } selected?={ settings.Model == option.ID }>{ option.Label }</option>
					}
				} else {
					for _, option := range OpenAIModelOptions {
						<option value={ option.ID } selected?={ settings.Model == option.ID }>{ option.Label }</option>
					}
				}
			</select>
		</label>
		<label class="block space-y-1 text-sm font-medium text-stone-900">
			<span class="flex items-center gap-2">
				OpenAI API key
				if settings.OpenAIAPIKey != "" {
					<span class="rounded-full bg-emerald-50 px-2 py-0.5 text-xs font-medium text-emerald-700 ring-1 ring-inset ring-emerald-600/20">Configured</span>
				}
			</span>
			<input
				type="password"
				name="openaiApiKey"
				autocomplete="off"
				placeholder="sk-…"
				class="block w-full rounded-lg border border-stone-300 px-3 py-2 font-mono text-sm"
			/>
		</label>
		<label class="block space-y-1 text-sm font-medium text-stone-900">
			<span class="flex items-center gap-2">
				Anthropic API key
				if settings.AnthropicAPIKey != "" {
					<span class="rounded-full bg-emerald-50 px-2 py-0.5 text-xs font-medium text-emerald-700 ring-1 ring-inset ring-emerald-600/20">Configured</span>
				}
			</span>
			<input
				type="password"
				name="anthropicApiKey"
				autocomplete="off"
				placeholder="sk-ant-…"
				class="block w-full rounded-lg border border-stone-300 px-3 py-2 font-mono text-sm"
			/>
		</label>
		<p class="text-xs text-stone-500">Leave a key field blank to keep the saved value. Keys are encrypted at rest on the server and are not sent back to the browser after save.</p>
		<button type="submit" class="inline-flex rounded-lg bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-500">
			Save settings
		</button>
		<div id="settings-status"></div>
	</form>
	<script>
		(() => {
			const provider = document.querySelector('select[name="provider"]');
			const model = document.querySelector('select[name="model"]');
			if (!provider || !model) return;
			const openai = [
				["gpt-4o-mini", "GPT-4o mini (recommended)"],
				["gpt-4o", "GPT-4o"],
				["gpt-4.1-mini", "GPT-4.1 mini"],
				["gpt-4.1", "GPT-4.1"],
			];
			const anthropic = [
				["claude-sonnet-4-20250514", "Claude Sonnet 4"],
				["claude-3-7-sonnet-20250219", "Claude 3.7 Sonnet"],
				["claude-3-5-haiku-20241022", "Claude 3.5 Haiku"],
			];
			const modelsByProvider = {};
			for (const option of provider.options) {
				modelsByProvider[option.value] = option.dataset.model || "";
			}
			function fill(options, selected) {
				model.replaceChildren();
				for (const [value, label] of options) {
					const option = document.createElement("option");
					option.value = value;
					option.textContent = label;
					if (value === selected) option.selected = true;
					model.appendChild(option);
				}
			}
			model.addEventListener("change", () => {
				modelsByProvider[provider.value] = model.value;
			});
			provider.addEventListener("change", () => {
				const options = provider.value === "anthropic" ? anthropic : openai;
				const selected = modelsByProvider[provider.value] || options[0][0];
				fill(options, selected);
			});
		})();
	</script>
}

templ SettingsSaved() {
	<p class="text-sm text-emerald-600">Settings saved.</p>
}

templ SettingsStatusError(message string) {
	<p class="text-sm text-red-600">{ message }</p>
}
