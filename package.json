{
  "name": "rubrical",
  "private": true,
  "packageManager": "pnpm@10.25.0",
  "scripts": {
    "css:build": "tailwindcss -i ./assets/css/input.css -o ./static/css/app.css --minify",
    "css:watch": "tailwindcss -i ./assets/css/input.css -o ./static/css/app.css --watch",
    "test:fixtures": "pnpm --filter rubrical-extension test:fixtures",
    "sanitize:fixtures": "node scripts/sanitize-fixtures.mjs"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.10",
    "tailwindcss": "^3.4.17"
  }
}
